{
  "expo": {
    "name": "Block Blast Arena",
    "slug": "block-blast-arena",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "block-blast-arena",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0F1A"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0F1A"
      },
      "package": "com.arenagames.blockblastarena"
    },
    "ios": {
      "bundleIdentifier": "com.arenagames.blockblastarena",
      "supportsTablet": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3386298011801498~1011417693",
          "iosAppId": "ca-app-pub-3386298011801498~1011417693"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "028fd02c-e9a0-47a1-b9ab-1fb40123d1e3"
      }
    }
  }
}
